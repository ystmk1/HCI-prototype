# Google Cloud Speech-to-Text API key
# Enable "Cloud Speech-to-Text API" in Google Cloud Console → APIs & Services
VITE_GOOGLE_STT_API_KEY=your_google_cloud_api_key_here

# Google Gemini API key
# Get from https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# OpenWakeWord WebSocket bridge URL (run wake_word_server/server.py locally)
# Defaults to ws://127.0.0.1:8765 if unset.
VITE_WAKE_WS_URL=ws://127.0.0.1:8765

# Supabase — dynamic few-shot prompt pool (optional)
# Create a project at https://supabase.com, run supabase/schema.sql, then paste
# Project URL + anon key here. Leave blank to disable (app still works).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
